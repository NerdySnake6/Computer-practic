      <con:testStep type="restrequest" name="GetCountryInfo" id="a3542289-4e09-402a-bf39-4d6d8ee1c3e3">
        <con:settings/>
        <con:config service="REST Countries API" resourcePath="/v3.1/name/{countryName}" methodName="GetCountryInfo" xsi:type="con:RestRequestStep" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
          <con:restRequest name="GetCountryInfoRequest" id="9e88d6ef-46c5-4d0f-a9db-84b2eb25e4c6" mediaType="application/json">
            <con:settings>
              <con:setting id="com.eviware.soapui.impl.wsdl.WsdlRequest@request-headers">&lt;xml-fragment/></con:setting>
            </con:settings>
            <con:endpoint>https://restcountries.com</con:endpoint>
            <con:request/>
            <con:originalUri>https://restcountries.com/v3.1/name/Finland</con:originalUri>
            <con:credentials>
              <con:authType>No Authorization</con:authType>
            </con:credentials>
            <con:jmsConfig JMSDeliveryMode="PERSISTENT"/>
            <con:parameters>
              <con:entry key="countryName" value="Finland"/>
            </con:parameters>
            <con:parameterOrder>
              <con:entry>countryName</con:entry>
            </con:parameterOrder>
            <con:assertions>
              <con:assertion type="Valid HTTP Status Codes" id="70570b74-124b-449e-b145-a92ad69b2d87" name="Valid HTTP Status Codes">
                <con:configuration>
                  <codes>200</codes>
                </con:configuration>
              </con:assertion>
            </con:assertions>
          </con:restRequest>
        </con:config>
      </con:testStep>
      <con:testStep type="transfer" name="CoordinateTransfer" id="3fbbd81e-bdbe-4cb9-b883-9b8897ee2e18">
        <con:settings/>
        <con:config xsi:type="con:PropertyTransfersStep" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
          <con:transfers transferToAll="false" useNullForMissingValue="true" ignoreEmptyvalue="false" failOnError="true" transferChildNodes="false" setOuterResults="false">
            <con:name>transferLatitude</con:name>
            <con:sourceType>Response</con:sourceType>
            <con:sourceStep>GetCountryInfo</con:sourceStep>
            <con:sourcePath>$[0].capitalInfo.latlng[0]</con:sourcePath>
            <con:targetType>latitude</con:targetType>
            <con:targetStep>GetWeather</con:targetStep>
            <con:targetPath/>
            <con:type>JSONPATH</con:type>
            <con:upgraded>true</con:upgraded>
          </con:transfers>
          <con:transfers transferToAll="false" useNullForMissingValue="true" ignoreEmptyvalue="false" failOnError="true" transferChildNodes="false" setOuterResults="false">
            <con:name>transferLongitude</con:name>
            <con:sourceType>Response</con:sourceType>
            <con:sourceStep>GetCountryInfo</con:sourceStep>
            <con:sourcePath>$[0].capitalInfo.latlng[1]</con:sourcePath>
            <con:targetType>longitude</con:targetType>
            <con:targetStep>GetWeather</con:targetStep>
            <con:targetPath/>
            <con:type>JSONPATH</con:type>
            <con:upgraded>true</con:upgraded>
          </con:transfers>
        </con:config>
      </con:testStep>
